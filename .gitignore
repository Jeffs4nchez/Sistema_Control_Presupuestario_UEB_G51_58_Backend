# ── Dependencias ────────────────────────────────────────────────────────────
/vendor
/node_modules

# ── Variables de entorno (NUNCA subir al repo) ───────────────────────────────
.env
.env.*
!.env.example

# ── Caché de Laravel (se regenera en Railway con artisan) ────────────────────
/bootstrap/cache/*.php
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
!storage/framework/cache/data/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
/storage/logs/*
!storage/logs/.gitkeep

# ── Archivos de subida de usuarios ───────────────────────────────────────────
/storage/app/public/*
!storage/app/public/.gitkeep
/public/storage
/storage/*.key

# ── Compilación ──────────────────────────────────────────────────────────────
/public/hot
/public/build

# ── Testing ──────────────────────────────────────────────────────────────────
.phpunit.result.cache
/.phpunit.cache
/storage/framework/testing/*
!storage/framework/testing/.gitkeep

# ── IDEs y editores ──────────────────────────────────────────────────────────
/.idea
/.vscode
/.fleet
/.nova
/.zed
.phpstorm.meta.php
_ide_helper.php
_ide_helper_models.php
.phpactor.json

# ── Sistema operativo ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Otros ────────────────────────────────────────────────────────────────────
/auth.json
Homestead.json
Homestead.yaml
/storage/pail
